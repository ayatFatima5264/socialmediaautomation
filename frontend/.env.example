# Frontend environment (Vite). Copy to .env.local and fill in as needed.
# Only VITE_-prefixed vars are exposed to the browser bundle.

# Canonical public origin — used for SEO canonical URLs, Open Graph, sitemap.
VITE_SITE_URL=https://autosocial.ai

# --- Analytics (optional; nothing loads unless an ID is set) ---------------
# Google Analytics 4 measurement ID, e.g. G-XXXXXXXXXX
VITE_GA_ID=
# Microsoft Clarity project ID
VITE_CLARITY_ID=

# --- Marketing contact form -----------------------------------------------
# Set to "true" once the backend POST /api/contact endpoint is implemented.
# Until then the form acknowledges submissions locally.
VITE_CONTACT_API=false
