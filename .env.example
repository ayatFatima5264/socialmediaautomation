# ---- AI provider --------------------------------------------------------
# Real free options: "gemini" (Google) or "groq" (Llama). "mock" = offline.
AI_PROVIDER=gemini

# Google Gemini — free key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Groq — free key from https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ---- Generation knobs ---------------------------------------------------
AI_REQUEST_TIMEOUT=30
AI_MAX_TOKENS=1024
AI_TEMPERATURE=0.8

# ---- Database -----------------------------------------------------------
# Production: PostgreSQL. Local fallback: sqlite:///./social_saas.db
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/social_saas

# ---- Auth ---------------------------------------------------------------
# Generate a strong secret, e.g.  python -c "import secrets;print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- Meta / Instagram Graph API -----------------------------------------
# From your Meta app at https://developers.facebook.com (App > Settings > Basic).
# Needed to exchange short-lived tokens for long-lived ones and for OAuth login.
# You can still connect with an already-long-lived token without these.
META_APP_ID=
META_APP_SECRET=
META_GRAPH_VERSION=v21.0
META_OAUTH_REDIRECT_URI=http://localhost:8000/api/accounts/instagram/callback
FRONTEND_URL=http://localhost:5173
