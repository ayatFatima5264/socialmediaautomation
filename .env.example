# ---- AI provider --------------------------------------------------------
# Real free options: "gemini" (Google) or "groq" (Llama). "mock" = offline.
AI_PROVIDER=gemini

# Google Gemini — free key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Groq — free key from https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ---- Generation knobs ---------------------------------------------------
AI_REQUEST_TIMEOUT=30
AI_MAX_TOKENS=1024
AI_TEMPERATURE=0.8

# ---- Database -----------------------------------------------------------
# Production: PostgreSQL. Local fallback: sqlite:///./social_saas.db
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/social_saas

# ---- Auth ---------------------------------------------------------------
# Generate a strong secret, e.g.  python -c "import secrets;print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- Meta OAuth (Facebook + Instagram) ----------------------------------
# A single Meta app powers both Facebook Login and Instagram (Instagram Business
# via Facebook Login). See "Meta OAuth Setup" in docs/OAUTH_CALLBACKS.md.
# Do NOT put real secrets in this example file — set them only in .env.
META_APP_ID=
META_APP_SECRET=
META_GRAPH_VERSION=v21.0
META_REDIRECT_URI=http://localhost:8000/api/auth/facebook/callback
# Instagram uses the same Meta app; only its redirect URI is separate.
INSTAGRAM_REDIRECT_URI=http://localhost:8000/api/auth/instagram/callback

FRONTEND_URL=http://localhost:5173

# ---- Social Accounts: OAuth 2.0 (other platforms) -----------------------
# Public base URL of THIS backend. Callback URLs derive from it as
#   {BACKEND_URL}/api/auth/{platform}/callback
# Register those exact URLs in each developer portal — full list + scopes in
# docs/OAUTH_CALLBACKS.md. A platform without credentials returns a clear error
# on Connect (there is no simulated/mock connect).
BACKEND_URL=http://localhost:8000

# One client id/secret pair per platform (create an app in each portal and
# register the matching callback URL above). Facebook & Instagram use the Meta
# credentials above instead.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
THREADS_CLIENT_ID=
THREADS_CLIENT_SECRET=
