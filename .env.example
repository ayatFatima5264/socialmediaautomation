# ---- AI provider --------------------------------------------------------
# "groq" (free Llama models) or "mock" (offline, no key needed).
AI_PROVIDER=groq

# Free key from https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ---- Generation knobs ---------------------------------------------------
AI_REQUEST_TIMEOUT=30
AI_MAX_TOKENS=1024
AI_TEMPERATURE=0.8

# ---- Database -----------------------------------------------------------
# Production: PostgreSQL. Local fallback: sqlite:///./social_saas.db
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/social_saas

# ---- Auth ---------------------------------------------------------------
# Generate a strong secret, e.g.  python -c "import secrets;print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
