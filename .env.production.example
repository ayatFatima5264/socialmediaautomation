# ===========================================================================
# AutoSocial AI — PRODUCTION environment template.
# Copy the values into your host's dashboard (Render/Railway "Environment" tab)
# or into a private .env.production file. NEVER commit real values — this file
# ships placeholders only. Generate secrets, don't reuse the dev ones.
# ===========================================================================

# ---- AI provider ----------------------------------------------------------
# "gemini" (Google) or "groq" (Llama). Set the matching API key below.
AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Generation knobs (safe defaults)
AI_REQUEST_TIMEOUT=30
AI_MAX_TOKENS=1024
AI_TEMPERATURE=0.8

# ---- Database (managed PostgreSQL) ----------------------------------------
# On Render this is injected automatically from the managed DB (see render.yaml).
# If setting manually, either scheme works — the app normalizes it to psycopg v3:
#   postgresql://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=postgresql://user:password@host:5432/autosocial

# ---- Auth / JWT -----------------------------------------------------------
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=generate-a-strong-random-64-char-hex-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- Public URLs (use your real HTTPS domains) ----------------------------
# Public origin of THIS backend. OAuth callbacks derive from it.
BACKEND_URL=https://api.yourdomain.com
# Where OAuth flows send the browser back to (your frontend).
FRONTEND_URL=https://app.yourdomain.com
# Allowed browser origins for CORS — a JSON list (pydantic parses it as JSON).
CORS_ORIGINS=["https://app.yourdomain.com"]

# ---- Scheduler ------------------------------------------------------------
SCHEDULER_POLL_SECONDS=30

# ---- Meta OAuth (Facebook + Instagram share one Meta app) -----------------
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_GRAPH_VERSION=v21.0
# Must EXACTLY match the redirect URIs registered in the Meta developer portal.
META_REDIRECT_URI=https://api.yourdomain.com/api/auth/facebook/callback
INSTAGRAM_REDIRECT_URI=https://api.yourdomain.com/api/auth/instagram/callback

# ---- Other social platform OAuth (fill in per platform you enable) --------
# Register {BACKEND_URL}/api/auth/{platform}/callback in each portal.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
THREADS_CLIENT_ID=
THREADS_CLIENT_SECRET=

# ---- AI image generation (Pollinations — free, no key) --------------------
POLLINATIONS_BASE=https://image.pollinations.ai
IMAGE_MODEL=flux
IMAGE_WIDTH=1080
IMAGE_HEIGHT=1080
